{
  "name": "economy-warfare",
  "version": "0.1.0",
  "private": true,
  "description": "Economy Warfare — browser card game (deck editor, online vs, solitaire). Embeddable as a modal via iframe.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:server": "npm run dev --workspace apps/server",
    "dev": "npm-run-all -p dev:web dev:server"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
